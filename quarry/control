-- Peripheral setup
local monitor = peripheral.find("monitor")
local manager = peripheral.find("chunkloader_manager")

if not monitor then
    error("No monitor found")
end

monitor.setTextScale(0.5)

rednet.open("left")

local turtles = {}
local selected = nil

-- UI layout
local mapWidth = 30
local sidebarX = mapWidth + 2

-- Draw everything
local function draw()
    monitor.setBackgroundColor(colors.black)
    monitor.clear()

    -- Title
    monitor.setCursorPos(1,1)
    monitor.setTextColor(colors.white)
    monitor.write("== Turtle Control ==")

    -- Map border
    for x = 1, mapWidth do
        monitor.setCursorPos(x,2)
        monitor.write("-")
    end

    -- Draw turtles
    for id, data in pairs(turtles) do
        local drawX = math.floor(data.x) + 15
        local drawY = math.floor(data.y) + 5

        if drawX > 0 and drawX <= mapWidth and drawY > 2 and drawY < 20 then
            monitor.setCursorPos(drawX, drawY)

            if id == selected then
                monitor.setTextColor(colors.yellow)
            else
                monitor.setTextColor(colors.green)
            end

            monitor.write("T")
        end
    end

    -- Sidebar header
    monitor.setCursorPos(sidebarX, 2)
    monitor.setTextColor(colors.cyan)
    monitor.write("Turtles:")

    local line = 3

    for id, data in pairs(turtles) do
        monitor.setCursorPos(sidebarX, line)

        local age = os.clock() - data.lastSeen
        local color = age > 10 and colors.red or colors.white

        monitor.setTextColor(color)
        monitor.write(id .. " (" .. data.x .. "," .. data.y .. "," .. data.z .. ")")

        line = line + 1
    end

    -- Selected turtle details
    if selected and turtles[selected] then
        local t = turtles[selected]

        monitor.setTextColor(colors.yellow)
        monitor.setCursorPos(sidebarX, line + 1)
        monitor.write("Selected: " .. selected)

        monitor.setCursorPos(sidebarX, line + 2)
        monitor.write("Status: " .. (t.status or "?"))

        monitor.setCursorPos(sidebarX, line + 3)
        monitor.write("Z: " .. t.z)

        -- Buttons
        monitor.setBackgroundColor(colors.blue)
        monitor.setCursorPos(sidebarX, line + 5)
        monitor.setTextColor(colors.white)
        monitor.write(" RETURN ")

        monitor.setBackgroundColor(colors.orange)
        monitor.setCursorPos(sidebarX, line + 7)
        monitor.write(" UPDATE ")

        monitor.setBackgroundColor(colors.purple)
        monitor.setCursorPos(sidebarX, line + 9)
        monitor.write(" WAKE ")

        monitor.setBackgroundColor(colors.lime)
        monitor.setCursorPos(sidebarX, line + 11)
        monitor.write(" LOAD ")

        monitor.setBackgroundColor(colors.black)
    end
end

-- Receive turtle updates
local function receive()
    while true do
        local id, msg, protocol = rednet.receive()

        if protocol == "miningTurtle" and type(msg) == "table" then
            msg.lastSeen = os.clock()
            turtles[id] = msg
        end
    end
end

-- Handle monitor clicks
local function handleTouch()
    while true do
        local event, side, x, y = os.pullEvent("monitor_touch")

        -- Select turtle
        for id, data in pairs(turtles) do
            local tx = math.floor(data.x) + 15
            local ty = math.floor(data.y) + 5

            if x == tx and y == ty then
                selected = id
            end
        end

        -- Buttons
        if selected then
            local baseLine = 10

            if x >= sidebarX and x <= sidebarX + 10 then
                if y == baseLine then
                    rednet.send(selected, "return")

                elseif y == baseLine + 2 then
                    rednet.send(selected, "update")

                elseif y == baseLine + 4 and manager then
                    manager.wake(selected)

                elseif y == baseLine + 6 and manager then
                    manager.setRadius(selected, 1)
                end
            end
        end
    end
end

-- Render loop
local function render()
    while true do
        draw()
        sleep(0.2)
    end
end

parallel.waitForAny(receive, render, handleTouch)
